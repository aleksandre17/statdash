{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Path aliases — engine/ at repo root contains all platform layers */
    "baseUrl": ".",
    "paths": {
      "@/*":                       ["./src/*"],
      "@plugins":                  ["../../engine/plugins"],
      "@plugins/*":                ["../../engine/plugins/*"],
      "@geostat/plugins":          ["../../engine/plugins"],
      "@geostat/plugins/catalog":  ["../../engine/plugins/catalog.ts"],
      "@geostat/plugins/registry": ["../../engine/plugins/registry.ts"],
      "@geostat/expr":             ["../../engine/expr/index.ts"],
      "@geostat/expr/*":           ["../../engine/expr/src/*"],
      "@geostat/styles":           ["../../engine/styles/src/index.ts"],
      "@geostat/styles/*":         ["../../engine/styles/src/*"],
      "@geostat/engine":           ["../../engine/core/src/index.ts"],
      "@geostat/engine/*":         ["../../engine/core/src/*"],
      "@geostat/react":            ["../../engine/react/src/index.ts"],
      "@geostat/react/*":          ["../../engine/react/src/*"]
    }
  },
  "include": ["src"]
}
