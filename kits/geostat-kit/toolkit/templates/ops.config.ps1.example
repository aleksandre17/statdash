# Copy to <module>/ops.config.ps1 (e.g. frontend/ops.config.ps1)
$OpsSecretsModule = "frontend"
$OpsComposeFile     = "docker-compose.yml"

# --- Remote dev (geostat <module> dev bootstrap|sync|watch) ---
