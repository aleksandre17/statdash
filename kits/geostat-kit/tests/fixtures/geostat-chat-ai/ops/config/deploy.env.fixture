# Synthetic fixture identity — recreated by conftest into deploy.env (gitignored).
#
# No COMPOSE_*_SERVICE overrides: the compose slug derives from the project
# folder name (geostat-chat-ai), so service names resolve to geostat-chat-ai-*
# purely from the slug. This keeps the default-naming contract
# (compose_service_names) and the legacy-migrate-rename map consistent with one
# source of truth (the folder name), instead of duplicated override values.
DEPLOY_PROJECT=geostat-chat-ai
DOCKER_NETWORK=geostat-chat-ai-net
