# Shared deploy — copy to deploy.env (gitignored)
# Compose service names: geostat.ops.json modules + compose-gen (see lib/compose_identity.py).

DEPLOY_SERVER=user@YOUR_SERVER
DEPLOY_PROJECT=YOUR_PROJECT_SLUG

# COMPOSE_PROJECT_NAME=your-app
# DOCKER_NETWORK=your-app-net
# Legacy container names: profiles/legacy-server.env.example (COMPOSE_API_SERVICE, …)

