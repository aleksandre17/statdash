# docker-compose project env (ops/compose/.env) — auto-loaded by docker-compose for
# ${VAR} interpolation in docker-compose.prod.yml (distinct from the per-service
# env_file, which is container-side only). Copy to .env and fill real values; .env is
# gitignored (secrets). These MUST match ops/config/db/.env + the api DATABASE_URL.

POSTGRES_USER=statdash
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=statdash

# Published reverse-proxy ports (the ONLY published ports; the api stays internal).
GEOSTAT_PORT=8080
PANEL_PORT=8081
