# Shared deploy / SSH identity — copy to deploy.env (gitignored)
# Real DEPLOY_SERVER must live ONLY here — never commit deploy.env.

# --- SSH (required for remote deploy) ---
# Connection target: user@host or SSH alias from ~/.ssh/config
DEPLOY_SERVER=user@YOUR_SERVER_IP

# Optional SSH overrides
# DEPLOY_SSH_IDENTITY_FILE=~/.ssh/id_ed25519
# DEPLOY_SSH_OPTIONS=-o StrictHostKeyChecking=accept-new

# Remote base path on the server
# DEPLOY_SERVER_BASE=/home/user
DEPLOY_PROJECT=statdash

# --- Ports (local / compose) ---
# HOST_PORT=80
# APP_DEV_PORT=5171
