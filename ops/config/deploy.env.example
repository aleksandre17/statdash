# Shared deploy / SSH identity — copy to deploy.env (gitignored)
# Real DEPLOY_SERVER must live ONLY in deploy.env — never commit it.

# --- SSH (required for remote deploy) ---
# Connection target: user@host OR a Host alias from ops/config/ssh/config.
DEPLOY_SERVER=geostat-deploy

# Optional project-local SSH (never commit private keys):
DEPLOY_SSH_CONFIG_FILE=ops/config/ssh/config
# DEPLOY_SSH_OPTIONS=-o StrictHostKeyChecking=accept-new

# Remote tree: $DEPLOY_SERVER_BASE/$DEPLOY_PROJECT/{api|geostat|panel|infra}/...
DEPLOY_SERVER_BASE=/home/administrator
DEPLOY_PROJECT=statdash

# --- Compose identity (override only if needed) ---
# COMPOSE_PROJECT_NAME=statdash
# DOCKER_NETWORK=statdash-net

# --- Ports (local / compose) ---
# API_HOST_PORT=3001
# DEPLOY_HOST_PORT=5171
