# @statdash/api — environment contract (validated in platform/apps/api/src/env.ts,
# fail-fast on boot). Copy to .env (gitignored) and replace every secret.
#   cp ops/config/api/.env.example ops/config/api/.env
#
# Authoritative source for these vars: platform/apps/api/src/env.ts — do not add
# vars here that env.ts does not parse (they would be silently ignored).

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5175
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Connects to statdash-pgbouncer (the pgBouncer container), NOT directly to postgres.
# User/db/password must match ops/config/db/.env (POSTGRES_USER / POSTGRES_DB / POSTGRES_PASSWORD).
DATABASE_URL=postgres://statdash:changeme_dev_only@statdash-pgbouncer:5432/statdash

# ── Auth (config routes are JWT-protected; stats + health stay public) ─────────
# JWT_SECRET must be >= 32 random chars (HMAC-SHA256 key strength). Rotate per env.
JWT_SECRET=change-me-to-at-least-32-random-chars
# Bootstrap admin — accepted ONLY while no admin user exists (fresh install login).
# Once a real admin is created (POST /api/admin/setup) these are ignored.
ADMIN_USERNAME=admin
# ADMIN_PASSWORD must be >= 8 chars. Use a strong, env-specific value.
ADMIN_PASSWORD=change-me-strong-password

# ── Embed signing (N38 snapshot embed tokens) ──────────────────────────────────
# HMAC-SHA256 secret. The dev default keeps local boot frictionless; production
# MUST override it (only thing between a leaked token and a forged one).
EMBED_SECRET=dev-secret-change-in-prod

# ── File-based provisioning (P2-5 GitOps) ──────────────────────────────────────
# DIR is scanned on boot for *.json / *.yaml / *.yml config.
# DRY_RUN=true logs planned upserts without writing (CI validation).
PROVISIONING_DIR=./provisioning
PROVISIONING_DRY_RUN=false
