# Infra remote deploy — copy to .env.deploy (gitignored)
# Shared SSH/project: ops/config/deploy.env (DEPLOY_SERVER, DEPLOY_PROJECT)
#
# Shared server root (DEPLOY_PROJECT=statdash in ops/config/deploy.env):
#   /home/administrator/statdash/
#     api/        ← @statdash/api (Fastify)
#     geostat/    ← SDUI runner dist
#     panel/      ← Constructor dist
#     infra/
#       <INFRA_SLUG>/   ← this consumer's Postgres stack
#         compose/
#         .env.runtime
#
# INFRA_SLUG = repo/project slug (statdash). Must match .env.dev INFRA_SLUG.
# Fallback if DEPLOY_PATH empty: {DEPLOY_SERVER_BASE}/{DEPLOY_PROJECT}/infra/{INFRA_SLUG}

INFRA_SLUG=statdash
DEPLOY_PATH=/home/administrator/statdash/infra/statdash
