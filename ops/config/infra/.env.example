# ops/config/infra — copy to .env.dev and .env.prod (gitignored)
# Used by: ops/compose/infra/* (docker-compose.base.yml --env-file)
#
# Our infra stack is Postgres-family only (postgres + pgbouncer + pgadmin + flyway).
# Postgres CREDENTIALS live in ops/config/db/.env (POSTGRES_*) — NOT here.
# This file carries only the infra IDENTITY (project name, network, host port bind).
#
# Per-project infra on a shared server: {DEPLOY_PROJECT}/infra/<INFRA_SLUG>/.
# A second project on the same host: change INFRA_* + POSTGRES_PORT.

# --- Identity (unique per consumer repo on one server) ---
INFRA_SLUG=statdash
INFRA_PREFIX=statdash
INFRA_COMPOSE_PROJECT=statdash-infra

# --- Docker network (must match this repo's app compose / catalog) ---
DOCKER_NETWORK=statdash-net

# --- Host port (127.0.0.1 bind) — unique per INFRA_SLUG on shared server ---
POSTGRES_PORT=5432

# --- Hybrid (apps on host, infra in Docker on server) ---
# After `geostat infra tunnel`, infra is reachable at 127.0.0.1.
INFRA_HOST=127.0.0.1
