# @statdash/geostat (SDUI runner) — environment contract.
# Copy to .env.dev / .env.prod (gitignored). Vars are read at BUILD time by Vite
# (import.meta.env.*), so set them before building the dist.
#
# Authoritative source: platform/apps/geostat/src/{main.tsx,data/site-manifest.ts}.
# Only VITE_*-prefixed vars are exposed to the client bundle.

# ── Store mode (which data backend the dashboard reads) ────────────────────────
#   stats → live stats API (config.data_source manifest)   [fetchStats]
#   api   → mock API via MSW (in-bundle dataset fixtures)   [fetchApi]
#   (unset / anything else) → static in-bundle manifest     [fetchStatic]
VITE_STORE_MODE=

# ── Site mode (where the site MANIFEST comes from — orthogonal to store mode) ───
#   api → fetch bootstrap manifest from VITE_API_STATS_URL (falls back to local)
#   (unset / anything else) → local buildManifest()
VITE_SITE_MODE=

# ── Stats API base URL (used when VITE_STORE_MODE=stats or VITE_SITE_MODE=api) ──
# Defaults to http://localhost:3001 if unset.
VITE_API_STATS_URL=http://localhost:3001
