# @statdash/panel (Constructor) — environment contract.
# Copy to .env.dev / .env.prod (gitignored). Read at BUILD time by Vite.
#
# Authoritative source: platform/apps/panel/src/lib/{api.ts,auth.ts}.
# Only VITE_*-prefixed vars reach the client bundle.

# ── Constructor backend (the @statdash/api config + auth routes) ───────────────
# Defaults to http://localhost:3001 if unset.
VITE_API_URL=http://localhost:3001
