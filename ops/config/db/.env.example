# Database environment — copy to .env (gitignored) and replace secrets.
#   cp ops/config/db/.env.example ops/config/db/.env

# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=statdash
POSTGRES_USER=statdash
POSTGRES_PASSWORD=changeme_dev_only

# ── pgAdmin (dev only — not loaded in prod) ──────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@statdash.local
PGADMIN_DEFAULT_PASSWORD=changeme_dev_only
PGADMIN_LISTEN_PORT=5050
