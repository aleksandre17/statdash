# @statdash/api — environment contract (validated in src/env.ts, fail-fast on boot)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5175
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/statdash

# ── Auth (config routes are JWT-protected; stats + health stay public) ─────────
# JWT_SECRET must be >= 32 random chars (HMAC-SHA256 key strength). Rotate per env.
JWT_SECRET=change-me-to-at-least-32-random-chars
# P2-2: identities now live in config.user (DB-backed, scrypt-hashed). The two
# vars below are a BOOTSTRAP FALLBACK ONLY — login accepts them just while no
# admin user exists yet, so a fresh install can sign in. The moment a real admin
# is created (POST /api/admin/setup, or via /api/admin/users), they are ignored.
ADMIN_USERNAME=admin
# ADMIN_PASSWORD must be >= 8 chars. Use a strong, env-specific value.
ADMIN_PASSWORD=change-me-strong-password
