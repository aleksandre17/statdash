VITE_API_URL=http://localhost:3001

# AR-49 M1.2 — mount the new Studio authoring shell instead of the 3-step wizard.
# Off by default (wizard stays the default). Set to 'true' to preview the Studio.
# Live override without a rebuild: in the browser console run
#   localStorage.setItem('statdash.studioShell', 'on'); location.reload()
# and to revert: localStorage.setItem('statdash.studioShell', 'off') (or removeItem).
VITE_STUDIO_SHELL=false
