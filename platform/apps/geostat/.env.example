# App config
VITE_API_URL=http://YOUR_SERVER_IP:PORT

# Stats API base URL (used when VITE_STORE_MODE=stats).
# Defaults to http://localhost:3001 if unset.
VITE_API_STATS_URL=http://localhost:3001

# Deployment (required for deploy.ps1 / manage.ps1)
DEPLOY_SERVER=user@YOUR_SERVER_IP
DEPLOY_HOST_PORT=80
DEPLOY_PATH=/home/user/myproject/service-name

# Optional overrides
# DEPLOY_SERVER_BASE=/home/user   # default: derived from DEPLOY_SERVER user
