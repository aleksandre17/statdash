{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* Path aliases — packages/ at repo root contains all platform layers */
    "baseUrl": ".",
    "paths": {
      "@/*":                       ["./src/*"],
      "@statdash/contracts":        ["../../packages/contracts/src/index.ts"],
      "@statdash/contracts/*":      ["../../packages/contracts/src/*"],
      "@plugins":                  ["../../packages/plugins"],
      "@plugins/*":                ["../../packages/plugins/*"],
      "@statdash/plugins":          ["../../packages/plugins"],
      "@statdash/plugins/catalog":  ["../../packages/plugins/catalog.ts"],
      "@statdash/plugins/registry": ["../../packages/plugins/registry.ts"],
      "@statdash/plugins/datasources": ["../../packages/plugins/datasources/index.ts"],
      "@statdash/expr":             ["../../packages/expr/index.ts"],
      "@statdash/expr/*":           ["../../packages/expr/src/*"],
      "@statdash/styles":           ["../../packages/styles/src/index.ts"],
      "@statdash/styles/*":         ["../../packages/styles/src/*"],
      "@statdash/engine":           ["../../packages/core/src/index.ts"],
      "@statdash/engine/*":         ["../../packages/core/src/*"],
      "@statdash/charts":           ["../../packages/charts/src/index.ts"],
      "@statdash/charts/*":         ["../../packages/charts/src/*"],
      "@statdash/react":            ["../../packages/react/src/index.ts"],
      "@statdash/react/*":          ["../../packages/react/src/*"],

      /* Third-party deps live in this app's node_modules (declared as peers
         by the packages/* libraries). Package source is compiled in-graph here,
         so bare specifiers imported from packages/** must resolve to the app's
         node_modules — `moduleResolution: bundler` resolves relative to the
         importing file and cannot otherwise reach them. */
      "react-router-dom":          ["./node_modules/react-router-dom"],
      "apexcharts":                ["./node_modules/apexcharts"],
      "react-apexcharts":          ["./node_modules/react-apexcharts"],
      "leaflet":                   ["./node_modules/@types/leaflet"],
      "react-leaflet":             ["./node_modules/react-leaflet"],
      "i18next":                   ["./node_modules/i18next"]
    }
  },
  "include": ["src", "../../packages"],
  "exclude": ["../../packages/**/*.stories.tsx", "../../packages/**/*.stories.ts"]
}
