{
  "name": "@statdash/contracts",
  "version": "0.1.0",
  "description": "Zero-dependency shared boundary contracts — the single source of truth for DTOs that cross the api ↔ engine ↔ app boundary (no React, no engine internals).",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "source":  "./src/index.ts",
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema/page-config.schema.json": "./schema/page-config.schema.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "schema"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "publishConfig": {
    "access": "public"
  }
}
