          "type": "object",
          "properties": {
            "type": {
              "const": "growth"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "ratio-list"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "pivot"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "transform"
            }
          },
          "required": [
            "type"
          ]
        }
      ]
    },
