        },
        "path": {
          "type": "string",
          "description": "Page path / permalink segment"
        },
        "presentation": {
          "type": "object",
          "properties": {
            "color": {
              "title": "Page color",
              "description": "color field",
              "type": "string",
              "$comment": "color"
