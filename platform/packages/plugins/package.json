{
  "name": "@statdash/plugins",
  "version": "0.1.0",
  "description": "Platform vocabulary — node/panel/control descriptors and runtime implementations",
  "type": "module",
  "private": true,
  "exports": {
    "./catalog": {
      "source":  "./catalog.ts",
      "types":   "./dist/catalog.d.ts",
      "import":  "./dist/catalog.js",
      "default": "./dist/catalog.js"
    },
    "./registry": {
      "source":  "./registry.ts",
      "types":   "./dist/registry.d.ts",
      "import":  "./dist/registry.js",
      "default": "./dist/registry.js"
    },
    "./datasources": {
      "source":  "./datasources/index.ts",
      "types":   "./dist/datasources/index.d.ts",
      "import":  "./dist/datasources/index.js",
      "default": "./dist/datasources/index.js"
    },
    "./presentation": {
      "source":  "./presentation/index.ts",
      "types":   "./dist/presentation/index.d.ts",
      "import":  "./dist/presentation/index.js",
      "default": "./dist/presentation/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@statdash/engine": "workspace:*",
    "@statdash/react":  "workspace:*",
    "@statdash/charts": "workspace:*",
    "@statdash/styles": "workspace:*"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "ajv": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-router-dom": ">=6",
    "react-apexcharts": ">=1.4.0",
    "leaflet": ">=1.9.0",
    "react-leaflet": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react-apexcharts": { "optional": true },
    "leaflet": { "optional": true },
    "react-leaflet": { "optional": true }
  }
}
