{
  "name": "@statdash/engine",
  "version": "0.1.0",
  "description": "Pure TypeScript rendering engine — zero React, fully testable",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "source":  "./src/index.ts",
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "sideEffects": [
    "./src/index.ts",
    "./src/data/spec.ts",
    "./src/data/transform/index.ts",
    "./src/registry/resolvers.ts",
    "./src/registry/interpreters.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean"
  },
  "dependencies": {
    "@statdash/contracts": "workspace:*",
    "@statdash/expr": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
