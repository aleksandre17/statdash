# pnpm configuration
# shamefully-hoist=false is the pnpm default — listed here for explicitness.
# Strict isolation: each package can only access what it declares in dependencies.
# This is what guarantees apps/panel is split-ready (no phantom deps).
shamefully-hoist=false

# Don't block install on unresolved peer dependency warnings during migration.
strict-peer-dependencies=false

# Always link workspace packages (workspace:* protocol).
link-workspace-packages=true
