{
  "name": "statdash-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter ./apps/geostat run dev",
    "dev:geostat": "pnpm --filter ./apps/geostat run dev",
    "dev:panel": "pnpm --filter ./apps/panel   run dev",
    "dev:api": "pnpm --filter ./apps/geostat run dev:api",
    "build": "pnpm --filter ./apps/geostat run build",
    "build:geostat": "pnpm --filter ./apps/geostat run build",
    "build:panel": "pnpm --filter ./apps/panel   run build",
    "build:mock": "pnpm --filter ./apps/geostat run build:mock",
    "build:engine": "pnpm -r --filter './engine/*' run build",
    "release": "pnpm changeset publish",
    "lint": "eslint .",
    "preview": "pnpm --filter ./apps/geostat run preview",
    "test": "vitest run",
    "check-laws": "bash ops/scripts/check-laws.sh",
    "layer-status": "bash ops/scripts/layer-status.sh",
    "build-verify": "bash ops/scripts/build-verify.sh",
    "compose:up": "docker compose -f ops/compose/docker-compose.yml -f ops/compose/docker-compose.override.yml up",
    "compose:down": "docker compose -f ops/compose/docker-compose.yml down",
    "compose:prod": "docker compose -f ops/compose/docker-compose.yml -f ops/compose/docker-compose.prod.yml up -d"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.18",
    "axe-core": "^4.12.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "msw": "^2.13.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.6",
    "xlsx": "^0.18.5"
  }
}
