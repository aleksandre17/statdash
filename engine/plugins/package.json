{
  "name": "@geostat/plugins",
  "version": "0.1.0",
  "description": "Platform vocabulary — node/panel/control descriptors and runtime implementations",
  "type": "module",
  "private": true,
  "exports": {
    "./catalog": {
      "source":  "./catalog.ts",
      "types":   "./dist/catalog.d.ts",
      "import":  "./dist/catalog.js",
      "default": "./dist/catalog.js"
    },
    "./registry": {
      "source":  "./registry.ts",
      "types":   "./dist/registry.d.ts",
      "import":  "./dist/registry.js",
      "default": "./dist/registry.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup catalog.ts registry.ts --format esm --dts --clean"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@geostat/engine": "workspace:*",
    "@geostat/react":  "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
