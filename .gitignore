ops/config/**/.env.dev
ops/config/**/.env.prod
ops/config/**/.env.deploy
ops/config/deploy.env
ops/config/**/google-credentials.json

# Build artifacts
tsconfig.tsbuildinfo
*.tsbuildinfo

# Python test cache
.pytest_cache/

# Runtime logs
ops/logs/

# Claude conversation dumps
*.jsonl

# Session / analysis artifacts (user working files — not source)
user-messages.txt
pipeline_extracted.txt

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
work/live-shots/
