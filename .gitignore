img.png

# --- work-dir hygiene (canon: work/ = board only; docs/ = docs; no tracked scratch) ---
# Ephemera never belongs in git — screenshots, probes, capture manifests are regenerable.
work/**/*-shots/
work/**/*probe*.js
work/live-shots/
work/sweep/
# platform/work/ is dissolved — a rogue second work dir must not return
platform/work/

# owner ad-hoc review screenshots at repo root
/img*.png

# MCP + test artifacts (regenerable)
.playwright-mcp/
platform/**/test-results/
platform/apps/panel/.audit-shots/
work/**/sweep/
